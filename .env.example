# Copy to .env and fill in values
# cp .env.example .env && nano .env

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=your-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=forecasting
DB_PASSWORD=change_me_to_something_strong
DB_NAME=forecasting

# Async URL used by FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://forecasting:change_me_to_something_strong@db:5432/forecasting

# Sync URL used by Alembic migrations (psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://forecasting:change_me_to_something_strong@db:5432/forecasting

# ── CORS origins ──────────────────────────────────────────────────────────────
# Development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production (set automatically in docker-compose.prod.yml via DOMAIN)
# CORS_ORIGINS=["https://your-domain.com"]

# ── SSL / Let's Encrypt ───────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@your-domain.com

# ── Upload limit ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=50
